# Supabase (create project at https://supabase.com)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Cloud Vision (for score-photo Edge Function — set in Supabase secrets)
# GOOGLE_CLOUD_VISION_API_KEY=your-vision-api-key

# EAS project ID (from `eas init`)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Service role key — local scripts only, NEVER commit or ship in the app
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional overrides for scripts/create-admin.mjs
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=your-secure-password
# ADMIN_DISPLAY_NAME=Your Name
